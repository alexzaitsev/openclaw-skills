#!/usr/bin/env python3
"""Stage a validated OpenClaw inbound image inside the Anki workspace."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "lib"))

from inbound_media import ImageValidationError, stage_inbound_image  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Stage a validated OpenClaw inbound image for Anki vision."
    )
    parser.add_argument("--source", required=True, help="Inbound image path")
    parser.add_argument("--json", action="store_true", help="Print staged image metadata as JSON")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    try:
        image = stage_inbound_image(args.source)
        if args.json:
            print(json.dumps({
                "path": str(image.path), "sha256": image.sha256,
                "bytes": len(image.data), "media_type": image.media_type,
                "width": image.width, "height": image.height,
            }, ensure_ascii=False, sort_keys=True))
        else:
            print(image.path)
    except ImageValidationError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
