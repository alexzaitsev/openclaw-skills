#!/usr/bin/env python3
"""Reviewed settings and preview helper for Anki statistics cron jobs."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "lib"))

from anki_connect import AnkiConnectError, invoke  # noqa: E402
from stats_calculator import StatsDataError  # noqa: E402
from stats_cron import CronContractError, CronManager  # noqa: E402
from stats_runtime import collect_report, now_from_environment  # noqa: E402


def cmd_settings(args: argparse.Namespace) -> int:
    settings = CronManager().settings()
    if args.json:
        print(json.dumps({"jobs": settings}, ensure_ascii=False, sort_keys=True))
        return 0
    for item in settings:
        state = "enabled" if item["enabled"] else "disabled"
        print(
            f"{item['deck']}: {state}; {item['time']}; "
            f"{','.join(item['days'])}; {item['timezone']}"
        )
    return 0


def cmd_explain(_args: argparse.Namespace) -> int:
    print("Review answer: one rating 1-4 event; manual rating 0 rows are excluded.")
    print("Unique cards: distinct reviewed card IDs in the period.")
    print("Answer pass: ratings 2-4 divided by all included answer events.")
    print("True retention: first answer per card per local calendar day; 1 fails.")
    print("Learning item: one unique note, independent of directional card count.")
    print(
        "Mature learning item: every active non-suspended card has "
        "interval >= 21 days."
    )
    print(
        "Moved-card history follows the card's current deck; "
        "deleted cards are unavailable."
    )
    return 0


def cmd_preview(args: argparse.Namespace) -> int:
    settings = CronManager().settings(args.deck)[0]
    report = collect_report(
        args.deck,
        settings["timezone"],
        sync_first=False,
        now=now_from_environment(),
    )
    if args.json:
        payload = {key: value for key, value in report.items() if key != "text"}
        print(json.dumps(payload, ensure_ascii=False, sort_keys=True))
    else:
        print(report["text"])
    return 0


def cmd_configure(args: argparse.Namespace) -> int:
    if (
        args.enable is None
        and args.time is None
        and args.days is None
        and args.timezone is None
    ):
        raise CronContractError("Configure requires an enabled state or schedule change.")
    if args.execute and not args.plan_id:
        raise CronContractError("--execute requires the reviewed --plan-id.")
    manager = CronManager()
    if args.enable:
        decks = invoke("deckNames")
        if not isinstance(decks, list) or args.deck not in decks:
            raise StatsDataError(f"Exact Anki deck is unavailable: {args.deck}.")
    parameters = {
        "enabled": args.enable,
        "clock": args.time,
        "days": args.days,
        "timezone": args.timezone,
    }
    if args.execute:
        result = manager.apply(args.deck, args.plan_id, **parameters)
        _print_applied(result)
        return 0
    plan = manager.plan(args.deck, **parameters)
    _print_plan("configure", plan)
    return 0


def cmd_disable(args: argparse.Namespace) -> int:
    if args.execute and not args.plan_id:
        raise CronContractError("--execute requires the reviewed --plan-id.")
    manager = CronManager()
    if args.execute:
        result = manager.apply(args.deck, args.plan_id, enabled=False)
        _print_applied(result)
        return 0
    plan = manager.plan(args.deck, enabled=False)
    _print_plan("disable", plan)
    return 0


def _print_plan(operation: str, plan: dict[str, object]) -> None:
    current = plan["current"]
    proposed = plan["proposed"]
    assert isinstance(current, dict) and isinstance(proposed, dict)
    print(f"DRY RUN {operation}")
    print(f"deck: {plan['deck']}")
    print(f"current_enabled: {'yes' if current['enabled'] else 'no'}")
    print(f"proposed_enabled: {'yes' if proposed['enabled'] else 'no'}")
    print(
        f"current_schedule: {current['time']} {','.join(current['days'])} "
        f"{current['timezone']}"
    )
    print(
        f"proposed_schedule: {proposed['time']} {','.join(proposed['days'])} "
        f"{proposed['timezone']}"
    )
    print(f"proposed_cron: {proposed['cron']}")
    print(f"plan_id: {plan['plan_id']}")
    print("result: dry run only")


def _print_applied(result: dict[str, object]) -> None:
    settings = result["settings"]
    assert isinstance(settings, dict)
    print("EXECUTE statistics settings")
    print(f"deck: {result['deck']}")
    print(f"enabled: {'yes' if settings['enabled'] else 'no'}")
    print(
        f"schedule: {settings['time']} {','.join(settings['days'])} "
        f"{settings['timezone']}"
    )
    print(f"cron: {settings['cron']}")
    print("result: updated and verified")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage Anki statistics notifications.")
    subparsers = parser.add_subparsers(dest="command", required=True)

    settings = subparsers.add_parser("settings")
    settings.add_argument("--json", action="store_true")
    settings.set_defaults(func=cmd_settings)

    subparsers.add_parser("explain").set_defaults(func=cmd_explain)

    preview = subparsers.add_parser("preview")
    preview.add_argument("--deck", required=True, choices=["Español", "English"])
    preview.add_argument("--json", action="store_true")
    preview.set_defaults(func=cmd_preview)

    configure = subparsers.add_parser("configure")
    configure.add_argument("--deck", required=True, choices=["Español", "English"])
    configure.add_argument("--enable", dest="enable", action="store_const", const=True)
    configure.add_argument("--time")
    configure.add_argument("--days")
    configure.add_argument("--timezone")
    configure.add_argument("--plan-id", default="")
    configure.add_argument("--execute", action="store_true")
    configure.set_defaults(func=cmd_configure)

    disable = subparsers.add_parser("disable")
    disable.add_argument("--deck", required=True, choices=["Español", "English"])
    disable.add_argument("--plan-id", default="")
    disable.add_argument("--execute", action="store_true")
    disable.set_defaults(func=cmd_disable)
    return parser


def main() -> int:
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (AnkiConnectError, CronContractError, StatsDataError, ValueError) as exc:
        raise SystemExit(f"Error: {exc}") from None
